<UserControl x:Class="deavnote.app.Views.ConfirmationView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:loc="using:deavnote.app.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:deavnote.app.ViewModels"
             d:DesignHeight="200"
             d:DesignWidth="600"
             x:DataType="viewmodels:ConfirmationViewModel"
             mc:Ignorable="d">

    <Grid Margin="5"
          ColumnDefinitions="Auto, *, Auto" RowDefinitions="*, Auto">

        <ic:FluentIcon Grid.Row="0" Grid.Column="0"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       Icon="Warning" IconSize="Size28" />

        <TextBlock Grid.Row="0" Grid.Column="1"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="{Binding Message}" />

        <StackPanel Grid.Row="1" Grid.Column="1"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Orientation="Horizontal" Spacing="20">
            <Button Width="70"
                    Command="{Binding ConfirmCommand}"
                    Content="Yes" />
            <Button Width="70"
                    Command="{Binding DeclineCommand}"
                    Content="No" />
            <Button Width="70"
                    Command="{Binding CancelCommand}"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</UserControl>
