<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="200"
			 xmlns:dd="using:deavnote.app.DesignData"
			 xmlns:viewmodels="using:deavnote.app.ViewModels"
			 x:DataType="viewmodels:TimeEntryViewModel"
			 x:Class="deavnote.app.Views.TimeEntryView">

	<Grid Margin="5" ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto, *, Auto">
		<Button HorizontalAlignment="Right" Grid.Column="3" Grid.Row="0" Content="Expt." />

		<TextBlock Foreground="White" Grid.Column="0" Grid.ColumnSpan="3"
				   Grid.Row="1" Text="{Binding Code}" HorizontalAlignment="Center"
				   VerticalAlignment="Top" Margin="5"/>

		<TextBlock Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Text="{Binding Title}"
				   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5"/>

		<Button Grid.Column="0" Grid.Row="3" Content="en cours" IsEnabled="False" />

		<TextBlock Grid.Column="2" Grid.Row="3" Text="{Binding Duration}"/>

	</Grid>

</UserControl>
