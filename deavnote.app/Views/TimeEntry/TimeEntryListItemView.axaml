<UserControl x:Class="deavnote.app.Views.TimeEntry.TimeEntryListItemView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:deavnote.app.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:loc="using:deavnote.app.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:deavnote.app.ViewModels.TimeEntry"
             MinWidth="270"
             MaxWidth="270"
             d:DesignHeight="130"
             d:DesignWidth="270"
             x:DataType="viewmodels:TimeEntryListItemViewModel"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:DevTaskStateToIconConverter x:Key="DevTaskStateToIconConverter" />
        <conv:DevTaskStateToColorConverter x:Key="DevTaskStateToColorConverter" />
        <conv:TimeSpanToReadableDurationConverter x:Key="TimeSpanToReadableDurationConverter" />
    </UserControl.Resources>

    <Grid Margin="5"
          ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, *, Auto" RowSpacing="10">

        <WrapPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   ItemSpacing="5" Orientation="Horizontal">
            <SelectableTextBlock Classes="CardTitle Code"
                                 Text="{Binding TaskCode}"
                                 TextWrapping="Wrap" />
            <SelectableTextBlock Classes="CardTitle"
                                 Text="{Binding TaskName}"
                                 TextWrapping="Wrap" />
        </WrapPanel>

        <SelectableTextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                             Classes="CardContent"
                             Text="{Binding EntryName}"
                             TextWrapping="Wrap" />

        <Button Grid.Row="2" Grid.Column="0"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Classes="IconButton"
                Command="{Binding CopyToClipboardCommand}"
                ToolTip.Tip="{loc:Localize Key=TimeEntryListItemView_Copy_Tooltip}">
            <ic:FluentIcon Icon="Copy" />
        </Button>

        <TextBlock Grid.Row="2" Grid.Column="2"
                   HorizontalAlignment="Right"
                   Classes="CardLegend"
                   Text="{Binding EntryDuration, Converter={StaticResource TimeSpanToReadableDurationConverter}}" />

    </Grid>

</UserControl>
