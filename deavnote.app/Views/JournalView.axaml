<UserControl x:Class="deavnote.app.Views.JournalView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:loc="using:deavnote.app.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:teviews="using:deavnote.app.Views.TimeEntry"
             xmlns:viewmodels="using:deavnote.app.ViewModels"
             Width="300"
             d:DesignHeight="800"
             d:DesignWidth="400"
             x:DataType="viewmodels:JournalViewModel"
             mc:Ignorable="d">

    <Grid Margin="5"
          ColumnDefinitions="Auto, Auto, Auto, *, Auto, Auto, Auto" RowDefinitions="Auto,Auto, *">

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7"
                    Margin="0,5" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock Margin="5,0"
                       Classes="SectionHeader"
                       Text="{Binding DateCursor, StringFormat='{}{0:dddd dd MMM}'}"
                       ToolTip.Tip="{Binding DateCursor, StringFormat='{}{0:d}'}" />
            <Button Grid.Row="0" Grid.Column="0"
                    Classes="Icon"
                    Command="{Binding ChangeViewTypeCommand}"
                    ToolTip.Tip="{Binding ChangeViewTypeTooltip}">
                <ic:FluentIcon Icon="CalendarClock" IconSize="Size16" />
            </Button>
        </StackPanel>


        <Button Grid.Row="1" Grid.Column="0"
                Classes="Icon"
                Command="{Binding MoveDateCursorToPreviousDayCommand}"
                ToolTip.Tip="{loc:Localize Key=JournalView_GoToPreviousDay_Tooltip}">
            <ic:FluentIcon Icon="ArrowLeft" IconSize="Size16" />
        </Button>
        <Button Grid.Row="1" Grid.Column="1"
                Classes="Icon"
                Command="{Binding MoveDateCursorToNowCommand}"
                ToolTip.Tip="{loc:Localize Key=JournalView_GoToToday_Tooltip}">
            <ic:FluentIcon Icon="CalendarArrowCounterclockwise" IconSize="Size20" />
        </Button>
        <Button Grid.Row="1" Grid.Column="2"
                Classes="Icon"
                Command="{Binding MoveDateCursorToNextDayCommand}"
                ToolTip.Tip="{loc:Localize Key=JournalView_GoToNextDay_Tooltip}">
            <ic:FluentIcon Icon="ArrowRight" IconSize="Size16" />
        </Button>

        <Button Grid.Row="1" Grid.Column="4"
                Classes="Icon"
                Command="{Binding CopyToClipboardCommand}"
                ToolTip.Tip="{Binding CopyToClipboardTooltip}">
            <ic:FluentIcon Icon="DocumentCopy" />
        </Button>
        <Button Grid.Row="1" Grid.Column="6"
                Margin="15,0,0,0"
                Classes="Icon"
                Command="{Binding AddTimeEntryCommand}"
                ToolTip.Tip="{loc:Localize Key=JournalView_AddTimeEntry_Tooltip}">
            <ic:FluentIcon Icon="Add" />
        </Button>

        <ListBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                 Classes="Journal"
                 ItemsSource="{Binding TimeEntries}"
                 SelectedItem="{Binding SelectedTimeEntry}"
                 SelectionMode="Single">
            <ListBox.Styles>
                <Style Selector="ListBoxItem:selected teviews|TimeEntryListItemView">
                    <Setter Property="BorderBrush" Value="{StaticResource Violet1}" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemContainerTheme>
                <ControlTheme TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </ControlTemplate>
                    </Setter>
                </ControlTheme>
            </ListBox.ItemContainerTheme>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:TimeEntry.TimeEntryListItemViewModel">
                    <teviews:TimeEntryListItemView Margin="4,6" HorizontalAlignment="Stretch" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>

</UserControl>
