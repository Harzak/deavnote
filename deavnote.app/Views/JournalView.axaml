<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:viewmodels="using:deavnote.app.ViewModels"
			 xmlns:vmDesign="using:deavnote.app.DesignData.ViewModels"
			 xmlns:views="using:deavnote.app.Views"
			 mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
			 x:DataType="viewmodels:JournalViewModel"
			 x:Class="deavnote.app.Views.JournalView">

		<Grid Margin="5" RowDefinitions="Auto, *" ColumnDefinitions="Auto, Auto, *,Auto, Auto">

			<Button Content="Prev." Grid.Column="0" Grid.Row="0" />
			<Button Content="Curr." Grid.Column="1" Grid.Row="0" />
			<Button Content="Next." Grid.Column="2" Grid.Row="0" />

			<Button Content="Expt." Grid.Column="3" Grid.Row="0" />
			<Button Content="Ajout." Grid.Column="4" Grid.Row="0" />

			<TextBlock Grid.Column="0" Grid.Row="1" Foreground="White" Grid.ColumnSpan="5" 
					   Text="{Binding Greeting}" HorizontalAlignment="Center" />

			<ItemsControl  Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="5" ItemsSource="{Binding TimeEntries}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="viewmodels:TimeEntryViewModel">
						<views:TimeEntryView />
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</Grid>

</UserControl>
