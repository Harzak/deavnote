<Window x:Class="deavnote.app.Views.MainView"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:deavnote.app.Views"
        xmlns:vm="using:deavnote.app.ViewModels"
        Title="deavnote.app"
        d:DesignHeight="450"
        d:DesignWidth="800"
        x:DataType="vm:MainViewModel"
        Background="{DynamicResource CustomMainBackground}"
        Icon="/Assets/avalonia-logo.ico"
        mc:Ignorable="d">
    <Panel>

        <Grid ColumnDefinitions="Auto, *" RowDefinitions="*">
            <views:JournalView Grid.Row="0" Grid.Column="0"
                               DataContext="{Binding Journal}" />
            <views:TimeEntryDetailView Grid.Row="0" Grid.Column="1" />
        </Grid>


        <views:NotificationView DataContext="{Binding}" />
    </Panel>

</Window>
