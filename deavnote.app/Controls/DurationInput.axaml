<UserControl x:Class="deavnote.app.Controls.DurationInput"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia">

    <StackPanel HorizontalAlignment="Left"
                Orientation="Horizontal" Spacing="10">
        <MaskedTextBox x:Name="DurationTextBox"
                       Width="60"
                       VerticalAlignment="Bottom"
                       Classes="Title" Mask="00:00" />
        <RepeatButton x:Name="DecreaseButton" VerticalAlignment="Center">
            <ic:FluentIcon FontSize="18" Icon="SubtractCircle" />
        </RepeatButton>
        <RepeatButton x:Name="IncreaseButton" VerticalAlignment="Center">
            <ic:FluentIcon FontSize="18" Icon="AddCircle" />
        </RepeatButton>
    </StackPanel>
</UserControl>