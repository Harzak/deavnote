<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

		xmlns:ic="using:FluentIcons.Avalonia">
	<Design.PreviewWith>
		<Grid  Background="{DynamicResource CustomMainBackground}"
			   Height="150" Width="700"
			   ColumnDefinitions="100, *, 100"
			   RowDefinitions="Auto, *, Auto" >
			<Border Classes="BannerRed" Margin="50,50" Grid.Column="1" Grid.Row="1">

				<TextBlock Classes="Banner" Text="Sample Text Sample Text Sample Text" />

			</Border>
		</Grid>
	</Design.PreviewWith>

	<!--Custom Styles-->
	<!--TextBlock-->
	<Style Selector="TextBlock.Title">
		<Setter Property="Foreground" Value="{StaticResource White1Brush}" />
		<Setter Property="FontSize" Value="18" />
		<Setter Property="FontWeight" Value="Regular" />
		<Setter Property="Margin" Value="5,10" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>
	<Style Selector="TextBlock.Content">
		<Setter Property="Foreground" Value="{StaticResource White1Brush}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<Style Selector="TextBlock.CardLegend">
		<Setter Property="Foreground" Value="{StaticResource White3Brush}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="FontWeight" Value="Light" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<Style Selector="TextBlock.Banner">
		<Setter Property="Foreground" Value="{StaticResource White1Brush}" />
		<Setter Property="FontSize" Value="15" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<!--SelectableTextBlock-->
	<Style Selector="SelectableTextBlock.CardContent">
		<Setter Property="Foreground" Value="{StaticResource White1Brush}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>
	<Style Selector="SelectableTextBlock.CardTitle">
		<Setter Property="Foreground" Value="{StaticResource White1Brush}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="FontWeight" Value="DemiBold" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<!--Border-->
	<Style Selector="Border.BannerBlue">
		<Setter Property="Opacity" Value="0.8" />
		<Setter Property="Background" Value="SteelBlue" />
		<Setter Property="CornerRadius" Value="8" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="CadetBlue" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<Style Selector="Border.BannerViolet">
		<Setter Property="Opacity" Value="0.8" />
		<Setter Property="Background" Value="SlateBlue" />
		<Setter Property="CornerRadius" Value="8" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="MediumSlateBlue" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<Style Selector="Border.BannerGray">
		<Setter Property="Opacity" Value="0.8" />
		<Setter Property="Background" Value="SlateGray" />
		<Setter Property="CornerRadius" Value="8" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="LightSlateGray" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<Style Selector="Border.BannerRed">
		<Setter Property="Opacity" Value="0.8" />
		<Setter Property="Background" Value="DarkRed" />
		<Setter Property="CornerRadius" Value="8" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="Red" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<Style Selector="Border.BannerOrange">
		<Setter Property="Opacity" Value="0.8" />
		<Setter Property="Background" Value="DarkOrange" />
		<Setter Property="CornerRadius" Value="8" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="Orange" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<Style Selector="Border.BannerRed">
		<Setter Property="Opacity" Value="0.8" />
		<Setter Property="Background" Value="DarkRed" />
		<Setter Property="CornerRadius" Value="8" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="Red" />
		<Setter Property="Padding" Value="10" />
	</Style>

	<!--Button-->
	<Style Selector="Button">
		<Setter Property="BorderThickness" Value="0,0,0,1" />
		<Setter Property="CornerRadius" Value="5" />
		<Setter Property="Padding" Value="8,8" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
	</Style>

	<Style Selector="Button.Icon">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0,0,0,1" />
		<Setter Property="CornerRadius" Value="5" />
		<Setter Property="Padding" Value="8,8" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
	</Style>

	<!--TextBox-->
	<Style Selector="TextBox">
		<Setter Property="Background" Value="{StaticResource Grey2}" />
		<Setter Property="BorderBrush" Value="{StaticResource Grey3}" />
	</Style>
	<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="{StaticResource Grey1}"/>
		<Setter Property="BorderBrush" Value="{StaticResource White3}"/>
	</Style>

	<!--AutoCompleteBox-->
	<Style Selector="AutoCompleteBox">
		<Setter Property="Background" Value="{StaticResource Grey2}" />
		<Setter Property="BorderBrush" Value="{StaticResource Grey3}" />
	</Style>


	<!--  Custom Color Resources  -->
	<Styles.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="CustomLightBackground" Color="{StaticResource White1}" />
					<SolidColorBrush x:Key="LightTimeEntryBackground" Color="{StaticResource White1}" />
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="CustomDarkBackground" Color="{StaticResource Grey1}" />
					<SolidColorBrush x:Key="DarkTimeEntryBackground" Color="{StaticResource Grey2}" />
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>
		</ResourceDictionary>
	</Styles.Resources>

</Styles>
