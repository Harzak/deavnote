<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Shared input background  -->
    <Style Selector="TextBox, ComboBox, DatePicker">
        <Setter Property="Background" Value="{StaticResource Grey3}" />
        <Setter Property="BorderBrush" Value="{StaticResource Grey4}" />
    </Style>

    <!--  ListBox  -->
    <Style Selector="ListBox.Journal">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>

</Styles>